# ── Database ──────────────────────────────────────────────────────────
# Reuses botfarm from bot-army. If running standalone, create a new DB.
DATABASE_URL=postgresql://botfarm:your_password@localhost:5432/botfarm

# ── API Keys ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
VOYAGE_API_KEY=pa-xxxxx

# ── Telegram Bots ─────────────────────────────────────────────────────
# One token per bot. Get from @BotFather.
ANGLERS_BOT_TOKEN=your_telegram_bot_token_here

# ── Webhook Base URL ──────────────────────────────────────────────────
# The public HTTPS URL where Telegram delivers updates.
# Nginx routes /telebots/anglers/webhook → localhost:5010
WEBHOOK_BASE_URL=https://yourdomain.com/telebots

# ── Optional: Email notifications ─────────────────────────────────────
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# NOTIFICATION_EMAIL=
